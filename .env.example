# ─────────────────────────────────────────────────────────────
# 프롬프트 빌더 환경설정 (이 파일을 .env 로 복사해서 채우세요)
# ─────────────────────────────────────────────────────────────

# 회사 LiteLLM 게이트웨이 (OpenAI 호환) — 사내 게이트웨이 주소로 변경하세요.
# 또는 실행 후 설정 화면에서 직접 입력해도 됩니다.
UBION_LITELLM_URL=http://localhost:4000
UBION_LITELLM_KEY=PUT_YOUR_LITELLM_KEY_HERE

# 대화/프롬프트 산출용 텍스트 모델
CHAT_MODEL=deepseek-v4-flash

# 레퍼런스 이미지 분석용 비전(옴니모달) 모델 — 샤오미 MiMo-V2.5
# 사내 LiteLLM 등록 별칭이 다르면(mimo-v2.5 등) 설정 화면의 "연결 확인"으로 맞추세요.
VISION_MODEL=MiMo-V2.5

# 서버
HOST=127.0.0.1
PORT=8770
